{
  "name": "quickgraph-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typegen": "openapi-typescript \"${VITE_QUICKGRAPH_OPENAPI_URL:-http://127.0.0.1:8011/openapi.json}\" -o src/lib/api-types.ts",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "idb": "^8.0.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.1",
    "openapi-typescript": "7.13.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
